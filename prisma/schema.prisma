generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"  // Use MySQL instead of PostgreSQL
  url      = env("DATABASE_URL")
}

model User {
  id       String   @id @default(cuid())
  email    String   @unique
  name     String
  phone    String   // <-- Added phone field here
  password String
  role     Role
  orders   Order[]  @relation("CreatedOrders")
}

model Order {
  id                 Int      @id @default(autoincrement())
  customerName       String
  phoneNumber        String
  gst                String?   // ✅ Optional GST field
  totalAmount        Float
  modeOfPayment      String
  advanceAmount      Float
  lendingAmount      Float
  productImages      Json     // Changed from String[] to Json
  orderStatus        String
  paymentStatus      String    // recived ,due ,partial
  commentsFromStaff Json
  photosWithComments Json
  dateOfDelivery     DateTime
  orderCategory      String
  createdAt          DateTime @default(now())
  createdBy          User     @relation("CreatedOrders", fields: [createdById], references: [id])
  createdById        String
  assignees          Json     // <<< add this line for assignee array
  payments       Payment[] @relation("OrderPayments")
}


enum Role {
  super_admin
  admin
  sales_person
  worker
}


model Payment {
  id          Int       @id @default(autoincrement())
  amount      Float
  paymentDate DateTime  @default(now())
  method      String    // e.g., "cash", "card", "upi", etc.
  order         Order     @relation("OrderPayments", fields: [orderId], references: [id])
  orderId     Int
}